---
const stack = ['Python', 'TypeScript', 'Playwright', 'Backstage', 'AWS', 'Kafka'];

const socials = [
  {
    label: 'GitHub',
    href: 'https://github.com/jesuspb2',
    icon: `<path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"/>`,
  },
  {
    label: 'LinkedIn',
    href: 'https://linkedin.com/in/jesusprianbaena',
    icon: `<path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect x="2" y="9" width="4" height="12"/><circle cx="4" cy="4" r="2"/>`,
  },
  {
    label: 'Email',
    href: 'mailto:hi@jesuspb.dev',
    icon: `<path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/>`,
  },
];

const tabs = [
  { label: 'About',    href: '#about' },
  { label: 'Projects', href: '#projects' },
  { label: 'Blog',     href: '/blog' },
  { label: 'Contact',  href: '#contact' },
];
---

<section class="hero" id="home">
  <div class="container">

    <!-- Avatar -->
    <div class="avatar" aria-hidden="true">
      <span class="avatar-letter">J</span>
    </div>

    <!-- Name & role -->
    <h1 class="name">Jesús</h1>
    <p class="role">SDET &amp; Platform Engineer</p>

    <!-- Social icons -->
    <div class="social-row" role="list" aria-label="Social links">
      {socials.map(({ label, href, icon }) => (
        <a
          href={href}
          target={href.startsWith('mailto') ? undefined : '_blank'}
          rel={href.startsWith('mailto') ? undefined : 'noopener noreferrer'}
          class="icon-btn"
          aria-label={label}
          role="listitem"
        >
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" set:html={icon} />
        </a>
      ))}
    </div>

    <!-- Location -->
    <p class="location">
      <span class="dot-pulse" aria-hidden="true"></span>
      Remote · Europe
    </p>

    <!-- Tab nav -->
    <nav class="tabs" aria-label="Page sections">
      {tabs.map(({ label, href }) => (
        <a href={href} class="tab">{label}</a>
      ))}
    </nav>

    <!-- About content -->
    <div id="about" class="about">
      <p class="bio">
        I build testing infrastructure and developer platforms — the tooling that lets
        engineering teams ship faster and sleep better. Currently at XM, working remotely.
      </p>
      <ul class="stack" aria-label="Tech stack">
        {stack.map((t) => <li class="tag">{t}</li>)}
      </ul>
    </div>

  </div>
</section>

<style>
  .hero {
    padding-top: 5rem;
    padding-bottom: 1.5rem;
  }

  .container {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }

  /* ── Avatar ── */
  .avatar {
    width: 72px;
    height: 72px;
    border-radius: 50%;
    border: 1px solid var(--border);
    background: var(--surface);
    margin-bottom: 1.25rem;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .avatar-letter {
    font-size: 1.5rem;
    font-weight: 500;
    color: var(--text-muted);
    line-height: 1;
  }

  /* ── Name & role ── */
  .name {
    font-size: 1.75rem;
    font-weight: 600;
    letter-spacing: -0.02em;
    color: var(--text);
    margin-bottom: 0.35rem;
  }

  .role {
    font-size: 0.8rem;
    color: var(--text-muted);
    letter-spacing: 0.02em;
    margin-bottom: 1.5rem;
  }

  /* ── Social icons ── */
  .social-row {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    margin-bottom: 1rem;
    flex-wrap: wrap;
    justify-content: center;
  }

  .icon-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 34px;
    height: 34px;
    border: 1px solid var(--border);
    border-radius: 7px;
    color: var(--text-muted);
    background: transparent;
    transition: color 0.15s, border-color 0.15s, background-color 0.15s;
    flex-shrink: 0;
  }

  .icon-btn:hover {
    color: var(--text);
    border-color: var(--text-muted);
    background: var(--surface);
  }

  /* ── Location ── */
  .location {
    font-size: 0.75rem;
    color: var(--text-muted);
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    margin-bottom: 2rem;
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-color: var(--border);
  }

  .dot-pulse {
    display: inline-block;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--accent);
    flex-shrink: 0;
    animation: pulse 2.4s ease-in-out infinite;
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50%       { opacity: 0.4; transform: scale(0.8); }
  }

  /* ── Tabs ── */
  .tabs {
    display: flex;
    align-items: center;
    gap: 0;
    border: 1px solid var(--border);
    border-radius: 8px;
    overflow: hidden;
    margin-bottom: 3rem;
  }

  .tab {
    font-size: 0.72rem;
    color: var(--text-muted);
    padding: 0.45rem 1.1rem;
    transition: color 0.15s, background-color 0.15s;
    border-right: 1px solid var(--border);
  }

  .tab:last-child { border-right: none; }

  .tab:hover {
    color: var(--text);
    background: var(--surface);
  }

  /* ── About content ── */
  .about {
    text-align: left;
    width: 100%;
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 1.5rem;
    background: color-mix(in srgb, var(--surface) 60%, transparent);
  }

  .bio {
    font-size: 0.82rem;
    color: var(--text-muted);
    line-height: 1.75;
    margin-bottom: 1.25rem;
  }

  .stack {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    list-style: none;
  }
</style>

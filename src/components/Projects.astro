---
const projects = [
  {
    name: 'playwright-framework',
    description:
      'Opinionated Playwright setup with automatic retry logic, trace collection on failure, and Allure HTML reporting. Shared across multiple QA teams.',
    tags: ['Playwright', 'TypeScript', 'GitHub Actions'],
    github: 'https://github.com/jesuspb2',
    demo: null,
  },
  {
    name: 'backstage-test-plugin',
    description:
      'Backstage plugin that surfaces test coverage, flakiness scores, and CI health metrics for every service in the software catalog.',
    tags: ['Backstage', 'React', 'TypeScript'],
    github: 'https://github.com/jesuspb2',
    demo: null,
  },
  {
    name: 'kafka-test-harness',
    description:
      'Lightweight Python harness for testing Kafka producers and consumers. Supports embedded brokers, message assertions, and Schema Registry integration.',
    tags: ['Python', 'Kafka', 'pytest'],
    github: 'https://github.com/jesuspb2',
    demo: null,
  },
  {
    name: 'ephemeral-test-envs',
    description:
      'Terraform + GitHub Actions system that provisions isolated AWS test environments on demand. Environments spin up in ~3 min and auto-teardown after CI.',
    tags: ['Terraform', 'AWS', 'GitHub Actions'],
    github: 'https://github.com/jesuspb2',
    demo: null,
  },
];
---

<section class="projects" id="projects">
  <div class="container">

    <h2 class="section-title">Projects</h2>

    <div class="project-list">
      {projects.map((project) => (
        <div class="project-card">
          <div class="project-header">
            <h3 class="project-name">{project.name}</h3>
            <div class="project-links">
              {project.github && (
                <a
                  href={project.github}
                  target="_blank"
                  rel="noopener noreferrer"
                  aria-label={`${project.name} on GitHub`}
                  class="link-arrow"
                >↗</a>
              )}
              {project.demo && (
                <a
                  href={project.demo}
                  target="_blank"
                  rel="noopener noreferrer"
                  aria-label={`${project.name} demo`}
                  class="link-arrow"
                >↗</a>
              )}
            </div>
          </div>
          <p class="project-desc">{project.description}</p>
          <ul class="project-tags" aria-label="Technologies">
            {project.tags.map((t) => <li class="tag">{t}</li>)}
          </ul>
        </div>
      ))}
    </div>

  </div>
</section>

<style>
  .projects {
    padding-block: 5rem;
  }

  .section-title {
    font-size: 0.7rem;
    font-weight: 500;
    color: var(--text-muted);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    text-decoration: underline;
    text-underline-offset: 4px;
    text-decoration-color: var(--border);
    margin-bottom: 2rem;
  }

  .project-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .project-card {
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 1.1rem 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    transition: border-color 0.15s;
  }

  .project-card:hover {
    border-color: var(--text-muted);
  }

  .project-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 0.5rem;
  }

  .project-name {
    font-size: 0.825rem;
    font-weight: 500;
    color: var(--text);
    letter-spacing: -0.01em;
  }

  .link-arrow {
    font-size: 0.85rem;
    color: var(--text-muted);
    flex-shrink: 0;
    transition: color 0.15s, transform 0.15s;
    display: inline-block;
  }

  .link-arrow:hover {
    color: var(--accent);
    transform: translate(1px, -1px);
  }

  .project-desc {
    font-size: 0.775rem;
    color: var(--text-muted);
    line-height: 1.65;
  }

  .project-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.3rem;
    list-style: none;
    margin-top: auto;
  }

</style>

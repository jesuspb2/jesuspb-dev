<div class="status-bar" role="status" aria-label="Status">
  <span class="tag">[jesus]</span>
  <span>0:~*</span>
  <span class="spacer"></span>
  <span>portfolio</span>
  <span class="sep" aria-hidden="true">|</span>
  <span id="status-clock">00:00:00</span>
</div>

<style>
  .status-bar {
    position: sticky;
    bottom: 0;
    z-index: 100;
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 6px 14px;
    background: var(--accent);
    color: #0b0d0c;
    font-size: 11px;
    font-weight: 600;
  }

  .tag {
    background: #0b0d0c;
    color: var(--accent);
    padding: 1px 8px;
  }

  .spacer { flex: 1; }
  .sep    { opacity: 0.5; }
</style>

<script>
  const clockEl = document.getElementById('status-clock');
  const tick = () => {
    const d = new Date();
    const p = (n: number) => String(n).padStart(2, '0');
    if (clockEl) clockEl.textContent = `${p(d.getHours())}:${p(d.getMinutes())}:${p(d.getSeconds())}`;
  };
  tick();
  setInterval(tick, 1000);
</script>

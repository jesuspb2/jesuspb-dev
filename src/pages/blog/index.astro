---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const posts = allPosts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const fmt = (d: Date) => d.toISOString().slice(0, 10);
const kb  = (s: string) => s; // placeholder — could derive from frontmatter
---

<BaseLayout title="blog/ — Jesús" description="Writing on testing, platform engineering, and developer tooling.">
  <div class="page">

    <!-- mini chrome -->
    <div class="mini-chrome">
      <div class="dots" aria-hidden="true">
        <span class="d red"></span>
        <span class="d yellow"></span>
        <span class="d green"></span>
      </div>
      <a href="/" class="back">← ~/portfolio</a>
      <button id="theme-toggle" class="theme-btn">
        <span class="lbl-light">☀ light</span>
        <span class="lbl-dark">☾ dark</span>
      </button>
    </div>

    <!-- pane -->
    <div class="content">
      <section class="pane">
        <header class="pane-hd">
          <span class="bar">▎</span>
          <span class="lbl">blog/</span>
          <span class="gap"></span>
          <span class="meta">ls -t · {posts.length} posts</span>
        </header>
        <div class="pane-body">
          {posts.length === 0 ? (
            <p class="empty">no posts yet — check back soon.</p>
          ) : (
            <div class="post-list">
              {posts.map((post, i) => (
                <a href={`/blog/${post.id}`} class:list={['post-row', i < posts.length - 1 && 'dashed']}>
                  <span class="post-date">{fmt(post.data.pubDate)}</span>
                  <span class="post-tags">{post.data.tags.slice(0,2).join(', ')}</span>
                  <span class="post-file">{post.id}.md</span>
                </a>
              ))}
            </div>
          )}
        </div>
      </section>
    </div>

  </div>
</BaseLayout>

<style>
  .page { min-height: 100svh; display: flex; flex-direction: column; font-size: 13px; }

  /* mini chrome */
  .mini-chrome {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 10px 14px;
    border-bottom: 1px solid var(--border);
    background: var(--surface2);
    position: sticky;
    top: 0;
    z-index: 10;
  }

  .dots { display: flex; gap: 6px; }
  .d { width: 10px; height: 10px; border-radius: 50%; }
  .red    { background: #ff5f56; }
  .yellow { background: #ffbd2e; }
  .green  { background: #27c93f; }

  .back {
    font-size: 11px;
    color: var(--fg-dim);
    flex: 1;
    transition: color 0.12s;
  }
  .back:hover { color: var(--accent); }

  .theme-btn {
    border: 1px solid var(--border);
    background: transparent;
    color: var(--fg-dim);
    cursor: pointer;
    border-radius: 3px;
    font-size: 10px;
    padding: 3px 8px;
  }

  .lbl-light { display: none; }
  .lbl-dark  { display: inline; }
  [data-theme="light"] .lbl-light { display: inline; }
  [data-theme="light"] .lbl-dark  { display: none; }

  .content { padding: 12px 20px; flex: 1; }

  .pane { border: 1px solid var(--border); border-radius: 4px; background: var(--surface); }
  .pane-hd {
    display: flex; align-items: center; padding: 8px 14px;
    border-bottom: 1px solid var(--border); font-size: 11px;
    color: var(--fg-dim); background: var(--surface2);
  }
  .bar  { color: var(--accent); margin-right: 6px; }
  .lbl  { letter-spacing: 0.03em; }
  .gap  { flex: 1; }
  .meta { color: var(--fg-mute); font-size: 10px; }
  .pane-body { padding: 20px; }

  .post-list { display: flex; flex-direction: column; font-size: 12.5px; }

  .post-row {
    display: grid;
    grid-template-columns: 100px 120px 1fr;
    gap: 14px;
    align-items: center;
    padding: 8px 0;
    text-decoration: none;
    color: inherit;
  }
  .post-row.dashed { border-bottom: 1px dashed var(--border); }
  .post-row:hover .post-file { color: var(--accent); }

  .post-date  { color: var(--fg-mute); }
  .post-tags  { color: var(--number); font-size: 11px; }
  .post-file  { color: var(--fg); transition: color 0.12s; }

  .empty { color: var(--fg-mute); font-size: 12px; }

  @media (max-width: 540px) {
    .post-row { grid-template-columns: 90px 1fr; }
    .post-tags { display: none; }
  }
</style>

<script>
  document.getElementById('theme-toggle')?.addEventListener('click', () => {
    const isLight = document.documentElement.dataset.theme === 'light';
    if (isLight) {
      delete document.documentElement.dataset.theme;
      localStorage.setItem('theme', 'dark');
    } else {
      document.documentElement.dataset.theme = 'light';
      localStorage.setItem('theme', 'light');
    }
  });
</script>

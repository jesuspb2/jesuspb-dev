---
import BaseLayout from '../layouts/BaseLayout.astro';
import WindowChrome from '../components/WindowChrome.astro';
import Pane from '../components/Pane.astro';
import ContactForm from '../components/ContactForm';
import type { ImageMetadata } from 'astro';

import imgPython     from '../assets/skills/python.svg';
import imgTypeScript from '../assets/skills/typescript.svg';
import imgPlaywright from '../assets/skills/playwright.svg';
import awsSvgRaw     from '../assets/skills/aws.svg?raw';
import imgDocker     from '../assets/skills/docker.svg';
import imgTerraform  from '../assets/skills/terraform.svg';
import imgSql        from '../assets/skills/sql.svg';
import imgK6         from '../assets/skills/k6.png';
import imgKafka      from '../assets/skills/kafka.svg';
import imgGrafana       from '../assets/skills/grafana.svg';
import imgKubernetes    from '../assets/skills/kubernetes.svg';
import imgLinux         from '../assets/skills/linux.svg';
import imgBackstage     from '../assets/skills/backstage.svg';
import imgGithubActions from '../assets/skills/github-actions.svg';
import imgPytest        from '../assets/skills/pytest.svg';

const stack: Array<{ label: string; img?: ImageMetadata; darkInvert?: boolean; svgRaw?: string }> = [
  { label: 'Python',         img: imgPython     },
  { label: 'TypeScript',     img: imgTypeScript },
  { label: 'Playwright',     img: imgPlaywright },
  { label: 'AWS',            svgRaw: awsSvgRaw  },
  { label: 'Kafka',          img: imgKafka,      darkInvert: true },
  { label: 'Backstage',      img: imgBackstage               },
  { label: 'pytest',          img: imgPytest                 },
  { label: 'Docker',         img: imgDocker     },
  { label: 'Kubernetes',     img: imgKubernetes },
  { label: 'Terraform',      img: imgTerraform  },
  { label: 'GitHub Actions', img: imgGithubActions            },
  { label: 'Grafana',        img: imgGrafana    },
  { label: 'PostgreSQL',     img: imgSql        },
  { label: 'k6',             img: imgK6         },
  { label: 'Linux',          img: imgLinux      },
];

const projects = [
  {
    name: 'backstage-qa-plugin',
    desc: 'Internal Backstage plugin surfacing test coverage, flake rate and CI health per service. Owned E2E design and rollout to 40+ teams.',
    tags: ['Backstage','TypeScript','React'],
    stars: '★ 142', year: '2026',
    href: 'https://github.com/jesuspb2',
  },
  {
    name: 'pyramid-runner',
    desc: 'Opinionated orchestrator that runs unit / integration / contract / e2e layers in parallel with smart retries and flake quarantine.',
    tags: ['Python','pytest','Kafka'],
    stars: '★ 89', year: '2025',
    href: 'https://github.com/jesuspb2',
  },
  {
    name: 'playwright-sharder',
    desc: 'Dynamic sharding for Playwright on GitHub Actions. Cut median pipeline from 24m to 6m across the platform monorepo.',
    tags: ['TypeScript','Playwright','CI'],
    stars: '★ 67', year: '2025',
    href: 'https://github.com/jesuspb2',
  },
];

const experience = [
  { date: '2024-01', level: 'INFO', msg: 'joined XM Group as SDET & Platform Engineer', perf: false },
  { date: '2023-11', level: 'INFO', msg: 'rolled out backstage-qa-plugin to 40+ teams',   perf: false },
  { date: '2023-06', level: 'PERF', msg: 'cut CI pipeline 24m → 6m via dynamic sharding', perf: true  },
  { date: '2022-03', level: 'INFO', msg: 'promoted to Senior QA Engineer',                 perf: false },
  { date: '2020-09', level: 'INFO', msg: 'started career in test automation',               perf: false },
];

---

<BaseLayout>
  <div class="shell">

    <WindowChrome />

    <div class="content">

      <!-- identity (left on desktop, top on mobile/tablet) + whoami.py -->
      <div class="hero-identity-grid">

      <!-- identity: col-1 on desktop, row-1 on mobile/tablet -->
      <Pane label="identity">
        <div class="identity-head">
          <div class="avatar" aria-hidden="true">J</div>
          <div>
            <div class="id-name">Jesús Prian Baena</div>
            <div class="id-role">SDET &amp; Platform Engineer</div>
          </div>
        </div>
        <div class="id-meta">
          <div><span class="key">location </span>Europe · remote</div>
          <div><span class="key">timezone </span>UTC+1</div>
          <div><span class="key">pgp      </span>0xA7F3C2B...9D</div>
        </div>
        <div class="connect-list">
          {[
            { k: 'github  ', v: 'github.com/jesuspb2',      href: 'https://github.com/jesuspb2' },
            { k: 'linkedin', v: 'linkedin.com/in/jesusprianbaena', href: 'https://linkedin.com/in/jesusprianbaena' },
            { k: 'email   ', v: 'hello@jesuspb.dev',        href: 'mailto:hello@jesuspb.dev' },
].map(l => (
            <a
              href={l.href}
              target={l.href.startsWith('http') ? '_blank' : undefined}
              rel={l.href.startsWith('http') ? 'noopener noreferrer' : undefined}
              class="connect-row"
            >
              <span class="key">{l.k}</span>
              <span class="arr">→</span>
              <span class="str">{l.v}</span>
            </a>
          ))}
        </div>
      </Pane>

      <!-- whoami.py: col-2 on desktop, row-2 on mobile/tablet -->
      <div class="hero-wrap">
        <Pane label="whoami.py" noPad>
          <Fragment slot="right">
            <span class="meta-count meta-d">python · 17 lines</span>
            <span class="meta-count meta-m">python · 19 lines</span>
          </Fragment>

          <!-- Desktop: 17 lines -->
          <div class="code-grid code-d">
            <div class="ln" aria-hidden="true">1</div>
            <div class="cl"><span class="kw">class </span><span class="fn">Jesus</span><span class="fg">(SDET, PlatformEngineer):</span></div>

            <div class="ln" aria-hidden="true">2</div>
            <div class="cl i1"><span class="str">"""</span></div>

            <div class="ln" aria-hidden="true">3</div>
            <div class="cl i1"><span class="doc">SDET with 5+ years leading quality strategy</span></div>

            <div class="ln" aria-hidden="true">4</div>
            <div class="cl i1"><span class="doc">for cloud-native and platform engineering environments.</span></div>

            <div class="ln" aria-hidden="true">5</div>
            <div class="cl i1"><span class="doc">Currently at XM, owning the full test pyramid</span></div>

            <div class="ln" aria-hidden="true">6</div>
            <div class="cl i1"><span class="doc">for a Backstage-based IDP.</span></div>

            <div class="ln" aria-hidden="true">7</div>
            <div class="cl">&nbsp;</div>

            <div class="ln" aria-hidden="true">8</div>
            <div class="cl i1"><span class="doc">Passionate about shift-left testing and devex.</span></div>

            <div class="ln" aria-hidden="true">9</div>
            <div class="cl i1"><span class="str">"""</span></div>

            <div class="ln" aria-hidden="true">10</div>
            <div class="cl">&nbsp;</div>

            <div class="ln" aria-hidden="true">11</div>
            <div class="cl i1"><span class="fg">location  </span><span class="dim">= </span><span class="str">"Europe · remote"</span></div>

            <div class="ln" aria-hidden="true">12</div>
            <div class="cl i1"><span class="fg">currently </span><span class="dim">= </span><span class="str">"XM Group"</span></div>

            <div class="ln" aria-hidden="true">13</div>
            <div class="cl i1"><span class="fg">focus     </span><span class="dim">= [</span><span class="str">"shift-left"</span><span class="fg">, </span><span class="str">"devex"</span><span class="fg">, </span><span class="str">"idp"</span><span class="dim">]</span></div>

            <div class="ln" aria-hidden="true">14</div>
            <div class="cl i1"><span class="fg">years     </span><span class="dim">= </span><span class="num">5</span><span class="com"> # and counting</span></div>

            <div class="ln" aria-hidden="true">15</div>
            <div class="cl">&nbsp;</div>

            <div class="ln" aria-hidden="true">16</div>
            <div class="cl i1"><span class="kw">def </span><span class="fn">mission</span><span class="fg">(self):</span></div>

            <div class="ln" aria-hidden="true">17</div>
            <div class="cl i2"><span class="kw">return </span><span class="str">"ship fast, sleep better"</span></div>
          </div>

          <!-- Mobile: 19 lines (docstring split en líneas cortas) -->
          <div class="code-grid code-m">
            <div class="ln" aria-hidden="true">1</div>
            <div class="cl"><span class="kw">class </span><span class="fn">Jesus</span><span class="fg">(SDET, PlatformEngineer):</span></div>

            <div class="ln" aria-hidden="true">2</div>
            <div class="cl i1"><span class="str">"""</span></div>

            <div class="ln" aria-hidden="true">3</div>
            <div class="cl i1"><span class="doc">SDET with 5+ years leading quality strategy</span></div>

            <div class="ln" aria-hidden="true">4</div>
            <div class="cl i1"><span class="doc">for cloud-native environments. Currently</span></div>

            <div class="ln" aria-hidden="true">5</div>
            <div class="cl i1"><span class="doc">at XM, owning the full test pyramid</span></div>

            <div class="ln" aria-hidden="true">6</div>
            <div class="cl i1"><span class="doc">for a Backstage-based IDP.</span></div>

            <div class="ln" aria-hidden="true">7</div>
            <div class="cl">&nbsp;</div>

            <div class="ln" aria-hidden="true">8</div>
            <div class="cl i1"><span class="doc">Passionate about shift-left testing</span></div>

            <div class="ln" aria-hidden="true">9</div>
            <div class="cl i1"><span class="doc">and devex.</span></div>

            <div class="ln" aria-hidden="true">10</div>
            <div class="cl i1"><span class="str">"""</span></div>

            <div class="ln" aria-hidden="true">11</div>
            <div class="cl">&nbsp;</div>

            <div class="ln" aria-hidden="true">12</div>
            <div class="cl i1"><span class="fg">location  </span><span class="dim">= </span><span class="str">"Europe · remote"</span></div>

            <div class="ln" aria-hidden="true">13</div>
            <div class="cl i1"><span class="fg">currently </span><span class="dim">= </span><span class="str">"XM Group"</span></div>

            <div class="ln" aria-hidden="true">14</div>
            <div class="cl i1"><span class="fg">focus     </span><span class="dim">= [</span><span class="str">"shift-left"</span><span class="fg">, </span><span class="str">"devex"</span><span class="dim">]</span></div>

            <div class="ln" aria-hidden="true">15</div>
            <div class="cl i1"><span class="fg">years     </span><span class="dim">= </span><span class="num">5</span><span class="com"> # and counting</span></div>

            <div class="ln" aria-hidden="true">16</div>
            <div class="cl">&nbsp;</div>

            <div class="ln" aria-hidden="true">17</div>
            <div class="cl i1"><span class="kw">def </span><span class="fn">mission</span><span class="fg">(self):</span></div>

            <div class="ln" aria-hidden="true">18</div>
            <div class="cl i2"><span class="kw">return </span><span class="str">"ship fast, sleep better"</span></div>

            <div class="ln" aria-hidden="true">19</div>
            <div class="cl">&nbsp;</div>
          </div>
        </Pane>
      </div>

      </div><!-- /hero-identity-grid -->

      <!-- stack.toml -->
      <Pane id="stack" label="stack.toml" right={`${stack.length} entries`}>
        <div class="toml-header">[tools]</div>
        <div class="marquee-wrap">
          <div class="marquee-track">
            {[0, 1].map(setIdx => (
              <div class="marquee-set" aria-hidden={setIdx === 1 ? 'true' : undefined}>
                {stack.map(t => (
                  <span class="chip">
                    {t.svgRaw
                      ? <span class="chip-svg" title={t.label} set:html={t.svgRaw} />
                      : t.img
                        ? <img src={t.img.src} alt={t.label} title={t.label} class:list={['chip-img', t.darkInvert && 'chip-img--dark-invert']} />
                        : t.label
                    }
                  </span>
                ))}
              </div>
            ))}
          </div>
        </div>
      </Pane>

      <!-- projects/ -->
      <Pane id="projects" label="projects/" right={`${projects.length} repos`} noPad>
        {projects.map((p, i) => (
          <a
            href={p.href}
            target="_blank"
            rel="noopener noreferrer"
            class:list={['project-row', i < projects.length - 1 && 'divider']}
          >
            <div class="project-head">
              <span class="perm">drwxr-xr-x</span>
              <span class="pname">{p.name}/</span>
              <span class="flex1"></span>
              <span class="pmeta">{p.stars}</span>
              <span class="pmeta">{p.year}</span>
            </div>
            <p class="pdesc">{p.desc}</p>
            <div class="chips">
              {p.tags.map(t => <span class="chip">{t}</span>)}
            </div>
          </a>
        ))}
      </Pane>

      <!-- experience.log -->
      <Pane id="experience" label="experience.log" right="tail -n 20">
        <div class="exp-list">
          {experience.map(e => (
            <div class="exp-row">
              <span class="exp-date">{e.date}</span>
              <span class:list={['exp-level', e.perf && 'perf']}>[{e.level}]</span>
              <span class="exp-msg">{e.msg}</span>
            </div>
          ))}
        </div>
      </Pane>

<!-- contact -->
      <Pane id="contact" label="contact.sh">
        <div class="com contact-comment"># reach out — replies within 24h</div>
        <ContactForm client:load />
      </Pane>

    </div><!-- /content -->

  </div><!-- /shell -->
</BaseLayout>


<style>
  .shell {
    display: flex;
    flex-direction: column;
    min-height: 100svh;
  }

  .content {
    flex: 1;
    padding: 12px 20px 0;
  }

  /* ── Hero + identity grid ── */
  .hero-identity-grid {
    display: grid;
    grid-template-columns: 38fr 62fr;
    gap: 20px;
    align-items: stretch;
    margin-bottom: 20px;
  }

  .hero-wrap { height: 100%; }

  .meta-count { color: var(--fg-mute); font-size: 10px; }
  .meta-m     { display: none; }
  .code-grid.code-m { display: none; }

  .code-grid {
    display: grid;
    grid-template-columns: 40px 1fr;
    font-size: 13px;
    line-height: 1.7;
    padding: 14px 0;
    background-image: linear-gradient(
      to right,
      var(--gutter) 39px,
      var(--border) 39px,
      var(--border) 40px,
      transparent 40px
    );
  }

  .ln {
    text-align: right;
    padding: 0 10px;
    color: var(--fg-mute);
    font-size: 11px;
    user-select: none;
    display: flex;
    align-items: flex-start;
    justify-content: flex-end;
    padding-top: 0.15em;
  }

  .cl {
    padding: 0 18px;
    white-space: pre;
    overflow-x: auto;
    min-width: 0;
    display: flex;
    align-items: flex-start;
  }

/* Syntax tokens */
  .kw  { color: var(--keyword); }
  .fn  { color: var(--accent); }
  .str { color: var(--string); }
  .num { color: var(--number); }
  .com { color: var(--comment); font-style: italic; }
  .doc { color: var(--string); opacity: 0.75; font-style: italic; }
  .fg  { color: var(--fg); }
  .dim { color: var(--fg-dim); }
  .i1 { padding-left: calc(18px + 4ch); }
  .i2 { padding-left: calc(18px + 8ch); }

  /* ── Stack chips ── */
  .toml-header {
    font-size: 12px;
    color: var(--fg-dim);
    margin-bottom: 12px;
  }

  /* marquee */
  @keyframes marquee {
    from { transform: translateX(0); }
    to   { transform: translateX(-50%); }
  }

  .marquee-wrap {
    overflow: hidden;
    mask-image: linear-gradient(to right, transparent 0%, black 8%, black 92%, transparent 100%);
    -webkit-mask-image: linear-gradient(to right, transparent 0%, black 8%, black 92%, transparent 100%);
  }

  .marquee-track {
    display: flex;
    width: max-content;
    animation: marquee 35s linear infinite;
  }

  @media (max-width: 640px) {
    .marquee-track {
      animation: marquee 35s linear infinite;
    }
  }

  .marquee-set {
    display: flex;
    gap: 8px;
    padding-right: 8px; /* cierra el gap final para que 50% == ancho exacto de un set */
    flex-shrink: 0;
  }

  .marquee-wrap:hover .marquee-track {
    animation-play-state: paused;
  }

  .chips {
    display: flex;
    flex-wrap: wrap;
    gap: 5px;
  }

  .chip {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 3px 9px;
    font-size: 11px;
    color: var(--fg-dim);
    flex-shrink: 0;
  }

  .chip-img {
    width: 44px;
    height: 44px;
    object-fit: contain;
    display: block;
    filter: grayscale(20%);
    transition: filter 0.15s;
  }

  .chip:has(.chip-img),
  .chip:has(.chip-svg) {
    padding: 4px 14px;
  }

  .chip:hover .chip-img {
    filter: grayscale(0%);
  }

  :global(html:not([data-theme="light"])) .chip-img--dark-invert {
    filter: invert(1);
  }

  :global(html:not([data-theme="light"])) .chip:hover .chip-img--dark-invert {
    filter: invert(1) grayscale(0%);
  }

  .chip-svg {
    display: inline-flex;
    align-items: center;
  }

  .chip-svg :global(svg) {
    width: 44px;
    height: 44px;
    color: #252f3e;
  }

  :global(html:not([data-theme="light"])) .chip-svg :global(svg) {
    color: #ffffff;
  }

  /* ── Projects ── */
  .project-row {
    display: block;
    padding: 16px 20px;
    text-decoration: none;
    color: inherit;
    transition: background 0.12s;
  }

  .project-row:hover { background: var(--gutter); }

  .project-row.divider {
    border-bottom: 1px solid var(--border);
  }

  .project-head {
    display: flex;
    align-items: baseline;
    gap: 10px;
    margin-bottom: 6px;
  }

  .perm   { color: var(--fg-mute); font-size: 11px; }
  .pname  { color: var(--accent); font-size: 13px; font-weight: 600; }
  .flex1  { flex: 1; }
  .pmeta  { font-size: 11px; color: var(--fg-mute); }

  .pdesc {
    margin: 0 0 8px;
    color: var(--fg-dim);
    font-size: 12.5px;
    line-height: 1.6;
  }

  /* ── Experience ── */
  .exp-list {
    display: flex;
    flex-direction: column;
    gap: 10px;
    font-size: 12.5px;
  }

  .exp-row {
    display: grid;
    grid-template-columns: 72px 54px 1fr;
    gap: 12px;
    align-items: baseline;
  }

  .exp-date  { color: var(--fg-mute); }
  .exp-level { color: var(--accent); font-size: 11px; }
  .exp-level.perf { color: var(--number); }
  .exp-msg   { color: var(--fg); }

/* ── Contact ── */
  .contact-comment { font-size: 12px; margin-bottom: 20px; }

  /* Tablet: single-column so code-d has full width and nothing clips */
  @media (max-width: 1024px) {
    .hero-identity-grid { grid-template-columns: 1fr; }
  }

  @media (max-width: 640px) {
    .content { padding: 12px 10px 0; }

    .code-grid {
      grid-template-columns: 32px 1fr;
      font-size: 11px;
      background-image: linear-gradient(
        to right,
        var(--gutter) 31px,
        var(--border) 31px,
        var(--border) 32px,
        transparent 32px
      );
    }

    .i1 { padding-left: calc(18px + 2ch); }
    .i2 { padding-left: calc(18px + 4ch); }

    .meta-d { display: none; }
    .meta-m { display: inline; }
    .code-grid.code-d { display: none; }
    .code-grid.code-m { display: grid; }
  }

  /* identity pane */
  .identity-head {
    display: flex;
    align-items: center;
    gap: 14px;
    margin-bottom: 12px;
  }

  .avatar {
    width: 52px;
    height: 52px;
    border-radius: 50%;
    border: 1px solid var(--border-s);
    background: var(--surface2);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 20px;
    font-weight: 500;
    color: var(--fg);
    flex-shrink: 0;
  }

  .id-name  { font-size: 17px; font-weight: 600; color: var(--fg); }
  .id-role  { font-size: 12px; color: var(--fg-dim); }

  .id-meta {
    font-size: 12px;
    color: var(--fg-dim);
    line-height: 1.8;
  }

  .key { color: var(--fg-mute); }

  .connect-list {
    display: flex;
    flex-direction: column;
    gap: 10px;
    font-size: 12px;
    margin-top: 16px;
    border-top: 1px solid var(--border);
    padding-top: 12px;
  }

  .connect-row {
    display: flex;
    align-items: center;
    gap: 10px;
    text-decoration: none;
    color: inherit;
    padding: 4px 0;
  }

  .arr { color: var(--fg-mute); }
</style>
